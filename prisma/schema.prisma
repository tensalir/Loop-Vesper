// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  user
}

model Profile {
  id          String    @id @db.Uuid
  username    String?   @unique
  displayName String?   @map("display_name")
  avatarUrl   String?   @map("avatar_url")
  role        UserRole  @default(user) // 'admin' or 'user'
  pausedAt    DateTime? @map("paused_at")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  projects            Project[]
  generations         Generation[]
  projectMembers      ProjectMember[]
  modelPins           UserModelPin[]
  workflows           Workflow[]
  bookmarks           Bookmark[]
  notes               Note[]
  projectChats        ProjectChat[]
  pinnedImages        PinnedImage[]
  outputEvents        OutputEvent[]
  pdfBuckets          PdfBucket[]
  brandWorldLinks     BrandWorldProjectSettings[]
  timelineSequences   TimelineSequence[]
  timelineRenderJobs  TimelineRenderJob[]
  headlessCredentials HeadlessCredential[]

  @@map("profiles")
}

model Project {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  description   String?
  coverImageUrl String?  @map("cover_image_url")
  briefing      String?  @db.Text // High-level instructions that apply to all chats in this project
  ownerId       String   @map("owner_id") @db.Uuid
  isShared      Boolean  @default(true) @map("is_shared")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner              Profile                    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sessions           Session[]
  members            ProjectMember[]
  chats              ProjectChat[]
  pinnedImages       PinnedImage[]
  pdfBuckets         PdfBucket[]
  brandWorldSettings BrandWorldProjectSettings?
  timelineSequences  TimelineSequence[]

  @@index([ownerId])
  @@index([isShared, ownerId])
  @@index([updatedAt(sort: Desc), id(sort: Desc)]) // Keyset pagination
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String // 'viewer', 'editor', 'admin'
  joinedAt  DateTime @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  name      String
  type      String // 'image' or 'video'
  isPrivate Boolean  @default(true) @map("is_private")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  generations Generation[]

  @@index([projectId])
  @@index([projectId, isPrivate]) // For visibility queries
  @@map("sessions")
}

model Generation {
  id             String   @id @default(uuid()) @db.Uuid
  sessionId      String   @map("session_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  modelId        String   @map("model_id")
  prompt         String   @db.Text
  negativePrompt String?  @map("negative_prompt") @db.Text
  parameters     Json // Flexible params per model
  status         String // 'queued', 'processing', 'completed', 'failed'
  cost           Decimal? @db.Decimal(10, 6) // Cost in USD (e.g., 0.010000 for $0.01)
  createdAt      DateTime @default(now()) @map("created_at")

  session Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    Profile        @relation(fields: [userId], references: [id], onDelete: Cascade)
  outputs Output[]
  job     GenerationJob?

  @@index([sessionId])
  @@index([userId])
  @@index([sessionId, userId]) // Composite index for the query
  @@index([sessionId, status])
  @@index([sessionId, createdAt(sort: Desc), id(sort: Desc)]) // Keyset pagination (newest first)
  @@map("generations")
}

model GenerationJob {
  id           String    @id @default(uuid()) @db.Uuid
  generationId String    @unique @map("generation_id") @db.Uuid
  runAfter     DateTime? @map("run_after")
  attempts     Int       @default(0)
  lockedAt     DateTime? @map("locked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([lockedAt])
  @@index([runAfter])
  @@map("generation_jobs")
}

model Output {
  id           String   @id @default(uuid()) @db.Uuid
  generationId String   @map("generation_id") @db.Uuid
  fileUrl      String   @map("file_url")
  fileType     String   @map("file_type") // 'image' or 'video'
  width        Int?
  height       Int?
  duration     Float? // For videos
  isStarred    Boolean  @default(false) @map("is_starred") // Kept for backward compatibility
  isApproved   Boolean  @default(false) @map("is_approved") // New approval system (replaces star UI)
  createdAt    DateTime @default(now()) @map("created_at")

  generation Generation      @relation(fields: [generationId], references: [id], onDelete: Cascade)
  bookmarks  Bookmark[]
  notes      Note[]
  analysis   OutputAnalysis?
  events     OutputEvent[]

  @@index([generationId])
  @@index([generationId, fileType])
  @@index([generationId, createdAt(sort: Asc)]) // For ordering outputs within generation
  @@map("outputs")
}

// Semantic analysis of outputs (Gemini caption + Claude parsing)
model OutputAnalysis {
  id       String    @id @default(uuid()) @db.Uuid
  outputId String    @unique @map("output_id") @db.Uuid
  status   String    @default("queued") // 'queued', 'processing', 'completed', 'failed'
  attempts Int       @default(0)
  lockedAt DateTime? @map("locked_at")
  runAfter DateTime? @map("run_after")
  error    String?   @db.Text

  // Gemini caption results
  geminiCaption String? @map("gemini_caption") @db.Text
  geminiModel   String? @map("gemini_model")

  // Claude parsing results (structured JSON)
  claudeParsed Json?   @map("claude_parsed")
  claudeModel  String? @map("claude_model")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  output Output @relation(fields: [outputId], references: [id], onDelete: Cascade)

  @@index([status, lockedAt])
  @@index([status, runAfter])
  @@map("output_analyses")
}

model Note {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  outputId  String   @map("output_id") @db.Uuid
  text      String
  context   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  output Output  @relation(fields: [outputId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([outputId])
  @@map("notes")
}

model Model {
  id        String   @id
  name      String
  provider  String
  type      String[] // ['image', 'video']
  config    Json // Full model configuration
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  pins UserModelPin[]

  @@map("models")
}

model UserModelPin {
  userId   String @map("user_id") @db.Uuid
  modelId  String @map("model_id")
  pinOrder Int    @map("pin_order")

  user  Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  model Model   @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@id([userId, modelId])
  @@index([userId])
  @@map("user_model_pins")
}

model Workflow {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  name         String
  description  String?
  isTemplate   Boolean  @default(false) @map("is_template")
  workflowData Json     @map("workflow_data") // Node graph structure
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("workflows")
}

model Bookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  outputId  String   @map("output_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  output Output  @relation(fields: [outputId], references: [id], onDelete: Cascade)

  @@unique([userId, outputId])
  @@index([userId])
  @@index([outputId])
  @@map("bookmarks")
}

model PromptEnhancementPrompt {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  description  String?  @db.Text
  systemPrompt String   @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  modelIds     String[]
  createdBy    String   @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt
  updatedBy    String   @db.Uuid

  @@map("prompt_enhancement_prompts")
}

model ProductRender {
  id          String   @id @default(uuid()) @db.Uuid
  name        String // Product name / category (e.g., "MCL38")
  colorway    String? // Colorway / variant (e.g., "Papaya Orange")
  angle       String? // Angle / view (e.g., "front", "side", "3/4", "back")
  renderType  String?  @map("render_type") // Type: "single", "pair", or "case"
  sortOrder   Int      @default(0) @map("sort_order") // For ordering within colorway
  imageUrl    String   @map("image_url")
  storagePath String?  @map("storage_path") // Supabase path for local uploads
  source      String   @default("local") // "local" or "frontify"
  frontifyId  String?  @map("frontify_id") // Frontify asset ID if synced
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@index([name, colorway])
  @@index([name, renderType])
  @@index([source])
  @@map("product_renders")
}

// Brainstorm chat threads (per user + per project)
model ProjectChat {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @default("New Chat")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     Profile              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ProjectChatMessage[]

  @@index([projectId, userId])
  @@index([userId])
  @@map("project_chats")
}

// Individual messages within a brainstorm chat
model ProjectChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  chatId    String   @map("chat_id") @db.Uuid
  role      String // 'user' or 'assistant'
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  chat ProjectChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("project_chat_messages")
}

// Project-shared pinned reference images
model PinnedImage {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  imageUrl  String   @map("image_url")
  label     String? // Optional user-provided label
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  pinnedBy  String   @map("pinned_by") @db.Uuid // User who pinned the image

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [pinnedBy], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, sortOrder])
  @@map("pinned_images")
}

// Output event log (downloads, shares, etc.) for semantic analysis
model OutputEvent {
  id        String   @id @default(uuid()) @db.Uuid
  outputId  String   @map("output_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  eventType String   @map("event_type") // 'download', 'share', etc.
  metadata  Json? // Optional additional data (e.g., format, resolution)
  createdAt DateTime @default(now()) @map("created_at")

  output Output  @relation(fields: [outputId], references: [id], onDelete: Cascade)
  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([outputId])
  @@index([userId])
  @@index([eventType])
  @@index([createdAt(sort: Desc)])
  @@map("output_events")
}

// API usage counters for rate limiting (multi-user safe with atomic upserts)
// Used to track requests per minute/month to Google Gemini, Vertex AI, and Replicate
model ApiUsageCounter {
  id        String   @id @default(uuid()) @db.Uuid
  provider  String // 'gemini', 'vertex', 'replicate'
  scope     String // 'gemini-nano-banana-pro', 'gemini-veo-3.1', 'global'
  window    String // 'minute' or 'month'
  bucket    String // e.g., '2026-01-12T09:31Z' for minute, '2026-01' for month
  count     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, scope, window, bucket])
  @@index([provider, scope])
  @@index([bucket])
  @@map("api_usage_counters")
}

// --- PDF Buckets (per-user reference image extraction from PDFs) ---

model PdfBucket {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  fileName    String   @map("file_name")
  storagePath String?  @map("storage_path") // Original PDF in Supabase Storage
  status      String   @default("processing") // 'processing', 'completed', 'failed'
  pageCount   Int?     @map("page_count")
  error       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  images  PdfBucketImage[]

  @@index([projectId, userId])
  @@index([userId])
  @@map("pdf_buckets")
}

model PdfBucketImage {
  id          String   @id @default(uuid()) @db.Uuid
  bucketId    String   @map("bucket_id") @db.Uuid
  imageUrl    String   @map("image_url")
  storagePath String   @map("storage_path")
  width       Int?
  height      Int?
  pageIndex   Int?     @map("page_index") // PDF page the image was found on
  sortOrder   Int      @default(0) @map("sort_order")
  label       String? // Optional AI-generated or user label
  source      String   @default("embedded") // 'embedded', 'rendered', 'segmented'
  createdAt   DateTime @default(now()) @map("created_at")

  bucket PdfBucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)

  @@index([bucketId])
  @@index([bucketId, sortOrder])
  @@map("pdf_bucket_images")
}

// --- Monday–Figma–Frontify sync (chronology and mapping) ---

model SyncLink {
  id              String   @id @default(uuid()) @db.Uuid
  mondayItemId    String?  @map("monday_item_id")
  mondayBoardId   String?  @map("monday_board_id")
  figmaFileKey    String?  @map("figma_file_key")
  figmaNodeId     String?  @map("figma_node_id")
  frontifyAssetId String?  @map("frontify_asset_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  events    SyncEvent[]
  revisions SyncRevision[]

  @@unique([mondayItemId, mondayBoardId])
  @@unique([figmaFileKey, figmaNodeId])
  @@unique([frontifyAssetId])
  @@index([mondayItemId])
  @@index([figmaFileKey])
  @@index([frontifyAssetId])
  @@map("sync_links")
}

model SyncEvent {
  id             String   @id @default(uuid()) @db.Uuid
  idempotencyKey String   @unique @map("idempotency_key")
  linkId         String?  @map("link_id") @db.Uuid
  source         String // 'monday' | 'figma' | 'frontify'
  externalId     String   @map("external_id")
  version        String
  occurredAt     DateTime @map("occurred_at")
  kind           String // 'revision' | 'feedback' | 'approval'
  payload        Json // full normalized event
  createdAt      DateTime @default(now()) @map("created_at")

  link SyncLink? @relation(fields: [linkId], references: [id], onDelete: SetNull)

  @@index([linkId, occurredAt(sort: Asc)])
  @@index([source, externalId])
  @@index([occurredAt(sort: Desc)])
  @@map("sync_events")
}

model SyncRevision {
  id        String   @id @default(uuid()) @db.Uuid
  linkId    String   @map("link_id") @db.Uuid
  source    String
  version   String
  payload   Json // materialized latest revision
  updatedAt DateTime @updatedAt @map("updated_at")

  link SyncLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@unique([linkId, source])
  @@index([linkId])
  @@map("sync_revisions")
}

model SyncCursor {
  id          String   @id @default(uuid()) @db.Uuid
  integration String // 'monday', 'figma', 'frontify'
  cursorKey   String   @map("cursor_key") // e.g. boardId, fileKey, projectId
  cursor      String // opaque cursor (timestamp, id, etc.)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([integration, cursorKey])
  @@index([integration])
  @@map("sync_cursors")
}

model BrandWorldProjectSettings {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @unique @map("project_id") @db.Uuid
  linkedByUserId String   @map("linked_by_user_id") @db.Uuid
  source         String // 'created' or 'linked'
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  linkedBy Profile @relation(fields: [linkedByUserId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("brand_world_project_settings")
}

// ── Timeline Editor Models ──

model TimelineSequence {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  sessionId  String?  @map("session_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  name       String   @default("Untitled Sequence")
  durationMs Int      @default(0) @map("duration_ms")
  fps        Int      @default(30)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        Profile              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks      TimelineTrack[]
  transitions TimelineTransition[]
  renderJobs  TimelineRenderJob[]

  @@index([projectId])
  @@index([userId])
  @@index([projectId, updatedAt(sort: Desc)])
  @@map("timeline_sequences")
}

model TimelineTrack {
  id         String  @id @default(uuid()) @db.Uuid
  sequenceId String  @map("sequence_id") @db.Uuid
  kind       String // 'video', 'caption', 'audio'
  label      String  @default("Track")
  sortOrder  Int     @default(0) @map("sort_order")
  isMuted    Boolean @default(false) @map("is_muted")

  sequence TimelineSequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  clips    TimelineClip[]
  captions TimelineCaption[]

  @@index([sequenceId])
  @@index([sequenceId, sortOrder])
  @@map("timeline_tracks")
}

model TimelineClip {
  id               String  @id @default(uuid()) @db.Uuid
  trackId          String  @map("track_id") @db.Uuid
  outputId         String? @map("output_id") @db.Uuid
  fileUrl          String  @map("file_url")
  fileType         String  @map("file_type") // 'video', 'image', 'audio'
  startMs          Int     @map("start_ms")
  endMs            Int     @map("end_ms")
  inPointMs        Int     @default(0) @map("in_point_ms")
  outPointMs       Int     @map("out_point_ms")
  sourceDurationMs Int     @map("source_duration_ms")
  sortOrder        Int     @default(0) @map("sort_order")

  track TimelineTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([trackId])
  @@index([trackId, startMs])
  @@map("timeline_clips")
}

model TimelineTransition {
  id         String @id @default(uuid()) @db.Uuid
  sequenceId String @map("sequence_id") @db.Uuid
  type       String @default("cross_dissolve") // 'cross_dissolve'
  fromClipId String @map("from_clip_id") @db.Uuid
  toClipId   String @map("to_clip_id") @db.Uuid
  durationMs Int    @default(500) @map("duration_ms")

  sequence TimelineSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@map("timeline_transitions")
}

model TimelineCaption {
  id      String @id @default(uuid()) @db.Uuid
  trackId String @map("track_id") @db.Uuid
  text    String @db.Text
  startMs Int    @map("start_ms")
  endMs   Int    @map("end_ms")
  style   Json   @default("{}")

  track TimelineTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([trackId])
  @@index([trackId, startMs])
  @@map("timeline_captions")
}

model TimelineRenderJob {
  id           String    @id @default(uuid()) @db.Uuid
  sequenceId   String    @map("sequence_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  status       String    @default("queued") // 'queued', 'processing', 'completed', 'failed'
  progress     Int       @default(0) // 0-100
  resolution   Int       @default(1080)
  snapshotJson Json?     @map("snapshot_json") // Frozen timeline state at render time
  outputUrl    String?   @map("output_url")
  outputId     String?   @map("output_id") @db.Uuid
  error        String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  completedAt  DateTime? @map("completed_at")

  sequence TimelineSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  user     Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
  @@index([userId])
  @@index([status])
  @@map("timeline_render_jobs")
}

// ── Headless Vesper API + MCP credentials ──
//
// Scoped machine-to-machine credentials for the headless Vesper API and MCP
// surface. We never expose provider keys (Gemini/OpenAI/Replicate/Anthropic)
// to external callers. Instead, callers receive a `vsp_...` bearer token tied
// to a specific Profile owner and a specific allowlist of tools and models.
//
// `tokenHash` stores SHA-256 of the raw token. We never persist the raw token
// after creation; the single plaintext copy is shown once at creation time.
// `tokenPrefix` is the short non-secret prefix (e.g. `vsp_live_a1b2`) used in
// the dashboard, audit logs, and to disambiguate keys without leaking secrets.

model HeadlessCredential {
  id                 String    @id @default(uuid()) @db.Uuid
  ownerId            String    @map("owner_id") @db.Uuid
  name               String // Human-readable label (e.g. "Damien — Cursor")
  tokenHash          String    @unique @map("token_hash") // sha256 of raw token
  tokenPrefix        String    @map("token_prefix") // e.g. "vsp_live_a1b2"
  // Allowed tools and models — empty arrays mean "no access".
  // Tools mirror the MCP/REST surface names: 'enhance_prompt', 'iterate_prompt',
  // 'list_models', 'generate_asset' (the last is reserved for later phases).
  allowedTools       String[]  @default([]) @map("allowed_tools")
  allowedModels      String[]  @default([]) @map("allowed_models")
  // Per-credential rate limits. NULL means "use the default policy".
  rateLimitPerMinute Int?      @map("rate_limit_per_minute")
  rateLimitPerDay    Int?      @map("rate_limit_per_day")
  // Operational metadata.
  lastUsedAt         DateTime? @map("last_used_at")
  expiresAt          DateTime? @map("expires_at")
  revokedAt          DateTime? @map("revoked_at")
  revokedReason      String?   @map("revoked_reason")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  owner   Profile              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  usage   HeadlessUsageLog[]
  buckets HeadlessRateBucket[]

  @@index([ownerId])
  @@index([tokenPrefix])
  @@index([revokedAt])
  @@map("headless_credentials")
}

// Per-request audit log for the headless surface. Keep this lightweight: id,
// status, timing, model, route/tool, and a small JSON metadata payload. We
// never log raw bearer tokens, full base64 reference images, or upstream
// provider responses. `errorCategory` aligns with `lib/errors/classification`.

model HeadlessUsageLog {
  id            String   @id @default(uuid()) @db.Uuid
  credentialId  String   @map("credential_id") @db.Uuid
  ownerId       String   @map("owner_id") @db.Uuid
  surface       String // 'rest' | 'mcp'
  route         String // e.g. '/api/headless/v1/prompts/enhance'
  toolName      String?  @map("tool_name") // e.g. 'enhance_prompt'
  modelId       String?  @map("model_id")
  status        String // 'success' | 'error' | 'rate_limited' | 'forbidden'
  httpStatus    Int      @map("http_status")
  errorCategory String?  @map("error_category")
  durationMs    Int      @map("duration_ms")
  costUsd       Decimal? @map("cost_usd") @db.Decimal(10, 6)
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  credential HeadlessCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId, createdAt(sort: Desc)])
  @@index([ownerId, createdAt(sort: Desc)])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("headless_usage_logs")
}

// Durable rate-limit buckets keyed per credential and window. Unlike the
// in-memory `createRateLimiter` used for browser routes, these survive
// across serverless invocations and isolates so external callers cannot
// burst by hitting a fresh worker. `bucket` is an ISO-truncated label
// (e.g. '2026-05-04T11:48Z' for minute, '2026-05-04' for day).

model HeadlessRateBucket {
  id           String   @id @default(uuid()) @db.Uuid
  credentialId String   @map("credential_id") @db.Uuid
  window       String // 'minute' | 'day'
  bucket       String
  count        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  credential HeadlessCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@unique([credentialId, window, bucket])
  @@index([credentialId, window])
  @@index([bucket])
  @@map("headless_rate_buckets")
}
